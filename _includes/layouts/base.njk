<!doctype html>
<html {% if section %} data-current="{{ section }}"{% endif %} lang="en">

	{% include "components/head.njk" %}

	<body>

		<header>
			<em class="header-logo">
				<a href="{{ '/' | url }}"><span class="logo-icon"></span>{{ metadata.title }}</a>
			</em>
			{% include "components/nav.njk" %}
			<div class="header-cta">
				<a href="/contact/" class="btn-primary" style="padding: 0.5rem 1.5rem; font-size: 0.95rem;">Book a Tour</a>
			</div>
		</header>

		<main>
			{{ content | safe }}
		</main>

		{% include "components/footer.njk" %}

		<script>
			document.addEventListener("DOMContentLoaded", function(event) { 
				lucide.createIcons();
			});
		</script>
	</body>

</html>
